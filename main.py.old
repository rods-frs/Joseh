# IMPORTS
import subprocess  # Run shell commands
from os import system  # Execute system commands

#Keywords
OPEN_KEYWORDS = [ "open", "launch", "start", "run", "execute" ]
DATE_KEYWORDS = [ "date", "today's date", "what date", "what day is today", "what date is today", "current date", "today date", "day today", "tell me the date", "which day is today" ]

# GLOBAL VARIABLES
op = ""  # Program name to open
stop_flag = 0  # Exit flag
program_found = 0  # Program found flag

# MAIN PROGRAM LOOP
while stop_flag == 0:
    # Display available commands
    print("Available commands: \nopen <program_name>")
    print("="*30)
    usr_input = str(input("Type the command: "))

    # Parse command type
    if any(word in OPEN_KEYWORDS for word in usr_input.split()):
        
        # OPEN COMMAND
        # Extract program name
        input_split = usr_input.split()
        idx = 0
    
        while True:
            if input_split[idx] in OPEN_KEYWORDS:
                idx2 = idx + 1
                if input_split[idx2] == "up" or input_split[idx2] == "the":
                    idx2 += 1
                while program_found == 0:
                    # Get program name
                    op = input_split[idx2]

                    # Search for program location
                    raw_location = subprocess.check_output(f"whereis {op}", shell=True, text=True)
                    raw_location = raw_location.splitlines()
                    
                    # Parse output and extract path
                    before, sep, after = raw_location[0].partition(":")
                    
                    # Check if valid path found
                    if len(after) > 1:
                        # Get first path
                        location = after.split()[0]
                        program_found = 1
                    idx2 += 1
                break
            else: idx += 1

        # Verify program location
        input(f"Press ENTER to open the program located at this path: {location}")

        # Open program in background
        command = f"nohup {location} >/dev/null 2>&1 &"
        system(command)
        print(f"{op} opened successfully")
        print("="*30)

    elif any(p in usr_input for p in DATE_KEYWORDS):
        # DATE COMMAND
        system("date")

    elif usr_input == "exit":
        # EXIT COMMAND
        print("Exiting the program...")
        stop_flag = 1  # Break main loop
    else:
        # Invalid command
        print(f"{usr_input} is not a valid command")



